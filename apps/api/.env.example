PORT=3002
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sendam
# Comma-separated origins allowed to call the REST API (admin + landing apps).
# Required in production; when empty in dev, all origins are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 64-char hex (32 bytes). Generate your own — never reuse this placeholder.
# Used for aes-256-gcm encryption of wallet secret keys.
# openssl rand -hex 32
ENCRYPTION_KEY=
# Admin dashboard auth. ADMIN_PASSWORD is the login password; JWT_SECRET signs
# session tokens (use a long random value: openssl rand -hex 32). Both are
# required — the API will not start without them.
ADMIN_PASSWORD=
JWT_SECRET=
# Optional: admin session lifetime in hours (default 12).
ADMIN_SESSION_TTL_HOURS=12
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Meta App Secret — verifies the X-Hub-Signature-256 header on webhook POSTs.
# Required in production; without it, forged webhook events are rejected.
WHATSAPP_APP_SECRET=
# Per-user transfer guardrails (XLM). Defaults: 1000 / 5000 / 50.
MAX_SEND_AMOUNT=1000
DAILY_SEND_LIMIT=5000
MAX_SENDS_PER_DAY=50
# Request rate limits (Mongo-backed, shared across instances).
# REST API: max requests per IP per window. WhatsApp bot: max messages per
# sender per window.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
BOT_RATE_WINDOW_SEC=60
BOT_RATE_MAX=20
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Lisk L2 testnet (Lisk Sepolia). Official RPC is rate-limited; an alternative
# is https://lisk-sepolia.drpc.org if you hit limits during development.
# Note: unlike Stellar's Friendbot, there is no auto-fund API for Lisk
# Sepolia — new wallets must be funded manually via a faucet (see README).
LISK_CHAIN_ID=4202
LISK_RPC_URL=https://rpc.sepolia-api.lisk.com
LISK_EXPLORER_URL=https://sepolia-blockscout.lisk.com
# The REST wallet API (/api/wallet/*) is unauthenticated — the phone number in
# the request body is the only identity. It's disabled in production unless you
# set this to "true". Outside production it defaults to enabled for local tests.
ENABLE_WALLET_REST_API=false
# AI intent decoder (optional, off by default) — a fallback for WhatsApp
# messages the regex command parser can't confidently classify. Its output
# always flows through the same guardrails and confirmation flow as a typed
# command; it never executes a transfer directly. Requires a prompt to be
# seeded first — see apps/api/scripts/seed-prompt-template.js.
ANTHROPIC_API_KEY=
# claude-haiku-4-5 is the recommended default for this workload (high-volume,
# low-complexity classification). Leave unset in code and this falls back to
# a more capable model instead of silently using the cheap one — set this
# explicitly to opt into Haiku's cost/speed.
ANTHROPIC_MODEL=claude-haiku-4-5
ENABLE_AI_INTENT_DECODER=false
# Paymaster (optional) — a privately-run relayer that sponsors Lisk gas fees.
# Not part of this repo (see ARCHITECTURE.md). Leaving both unset simply
# disables sponsorship; Lisk sends still work self-funded either way.
PAYMASTER_SERVICE_URL=
PAYMASTER_API_KEY=
# Deposit notifications (scripts/notify-deposits.js) — run via external cron
# by default. Set NOTIFY_POLL_ENABLED=true only to run an in-process
# interval instead, and only on a single instance (see the script's header).
NOTIFY_POLL_ENABLED=false
NOTIFY_POLL_INTERVAL_MS=60000
# NGN price display (src/services/priceOracle.service.js). Swappable —
# official CBN vs. parallel-market rate is a product decision, not resolved
# here. Default provider (open.er-api.com) needs no API key; FX_API_KEY is
# only used if you swap in a provider that requires one.
FX_PROVIDER=exchangerate_api
FX_API_KEY=
